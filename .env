# ─────────────────────────────────────────────────────────────────────────────
# CA Permit RAG System — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME="CA Permit RAG System"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS — comma-separated origins, or * for all
ALLOWED_ORIGINS=["*"]

# ── Crawling ──────────────────────────────────────────────────────────────────
CRAWL_TIMEOUT_SECONDS=30
CRAWL_MAX_RETRIES=3
CRAWL_DELAY_SECONDS=1.0
CRAWL_MAX_PAGES_PER_DOMAIN=10

# ── Embedding Service ─────────────────────────────────────────────────────────
# Swap model by changing this value — no code changes needed
EMBEDDING_MODEL_NAME=all-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu        # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_LENGTH=512

# ── LLM Service ───────────────────────────────────────────────────────────────
# Choose backend outside production: ollama | huggingface | openai
LLM_BACKEND=ollama
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=google.gemma-3-12b-it
ENABLE_LOCAL_RAG=false
ENABLE_AUTO_CRAWL=false
SKIP_PERMIT_MAPPING=true

# Ollama settings (used when LLM_BACKEND=ollama)
LLM_MODEL_NAME=gemma3:4b
LLM_OLLAMA_BASE_URL=http://ollama:11434
LLM_MAX_NEW_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9

# HuggingFace settings (used when LLM_BACKEND=huggingface)
HF_MODEL_NAME=google/gemma-3-4b-it
HF_TOKEN=                   # your HuggingFace token (required for gated models)
HF_DEVICE=cpu               # cpu | cuda | mps

# OpenAI settings (used when LLM_BACKEND=openai)
OPENAI_API_KEY=             # your OpenAI API key
OPENAI_MODEL=gpt-4o-mini

# ── Vector DB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=permit_docs

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_BM25_WEIGHT=0.4
RAG_VECTOR_WEIGHT=0.6
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
