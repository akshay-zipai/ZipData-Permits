# ─────────────────────────────────────────────────────────────────────────────
# CA Permit & Renovation Agent — Environment Configuration
# Copy this file to .env and fill in the values for your target environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment selector ───────────────────────────────────────────────────────
# "local"      → uses OpenAI GPT for text + DALL-E for images
# "production" → uses AWS Bedrock for text; DALL-E or Titan for images
ENVIRONMENT=production


# ═════════════════════════════════════════════════════════════════════════════
# LOCAL MODE  (ENVIRONMENT=local)
# ═════════════════════════════════════════════════════════════════════════════

# Required for local mode — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# GPT model for permit Q&A and renovation suggestions
# Cheaper option: gpt-3.5-turbo  |  Better quality: gpt-4o
OPENAI_MODEL=gpt-4o-mini

# DALL-E model for images (dall-e-3 recommended, dall-e-2 is cheaper)
OPENAI_IMAGE_MODEL=dall-e-3


# ═════════════════════════════════════════════════════════════════════════════
# PRODUCTION MODE  (ENVIRONMENT=production)
# ═════════════════════════════════════════════════════════════════════════════

# AWS region where your Bedrock model access is granted
BEDROCK_REGION=us-east-1

# Bedrock model ID — must be enabled in your AWS account.
# Recommended options (all support the Converse API):
#   anthropic.claude-3-haiku-20240307-v1:0     ← fast, cheap
#   anthropic.claude-3-sonnet-20240229-v1:0    ← balanced
#   anthropic.claude-3-5-sonnet-20241022-v2:0  ← best quality
#   amazon.nova-lite-v1:0                      ← Amazon native, very fast
#   meta.llama3-8b-instruct-v1:0               ← open-source option
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Image generation in production:
#   false (default) → still uses DALL-E via OPENAI_API_KEY (simpler, higher quality)
#   true            → uses Amazon Titan Image Generator v2 (no OpenAI key needed)
BEDROCK_IMAGE=true
BEDROCK_IMAGE_MODEL_ID=amazon.titan-image-generator-v2:0

# AWS credentials — leave blank if using IAM role, ECS task role, or
# credentials already configured in ~/.aws/credentials / environment.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# When BEDROCK_IMAGE=false (default), images still come from DALL-E.
# In that case, set OPENAI_API_KEY above even in production mode.


# ═════════════════════════════════════════════════════════════════════════════
# SHARED SETTINGS  (apply to both local and production)
# ═════════════════════════════════════════════════════════════════════════════

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# RAG — number of permit KB chunks used per answer
RAG_TOP_K=5

# Renovation suggestions
MAX_SUGGESTIONS=5

# Set false to skip image generation entirely (faster, no image API cost)
GENERATE_IMAGES=true

# DALL-E image options (used when OPENAI_IMAGE_MODEL=dall-e-3)
IMAGE_SIZE=1024x1024       # 1024x1024 | 1792x1024 | 1024x1792
IMAGE_QUALITY=standard     # standard | hd  (hd costs 2x)

# LLM generation parameters
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
