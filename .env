ENVIRONMENT=prod

# Bedrock — credentials from EC2 IAM role, no keys needed
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=google.gemma-3-12b-it

# DALL-E image generation — still needs an OpenAI key
OPENAI_IMAGE_API_KEY=sk-your-key-here
OPENAI_IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=standard

MAX_SUGGESTIONS=5
