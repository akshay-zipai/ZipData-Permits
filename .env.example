# ── Provider: "openai" or "bedrock" ──────────────────────────────────────────
LLM_PROVIDER=openai

# ── OpenAI (required when LLM_PROVIDER=openai) ───────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ── AWS Bedrock (required when LLM_PROVIDER=bedrock) ─────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Image generation (always DALL-E; set key even in bedrock mode) ────────────
# Leave OPENAI_IMAGE_API_KEY blank to reuse OPENAI_API_KEY
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=standard

# ── General ───────────────────────────────────────────────────────────────────
MAX_SUGGESTIONS=5
